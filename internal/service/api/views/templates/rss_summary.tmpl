{{ define "rss_summary.tmpl" }}
<!DOCTYPE HTML>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RSS 피드 대시보드</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.45);
            --border-color: rgba(255, 255, 255, 0.08);
            --accent-color: #38bdf8;
            --accent-hover: #0ea5e9;
            --accent-glow: rgba(56, 189, 248, 0.4);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --badge-bg: rgba(56, 189, 248, 0.15);
            --badge-text: #7dd3fc;
            --glass-blur: blur(16px);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 4rem 2rem;
            line-height: 1.6;
            position: relative;
            overflow-x: hidden;
        }

        /* Animated Background Gradients */
        body::before, body::after {
            content: '';
            position: fixed;
            width: 800px;
            height: 800px;
            border-radius: 50%;
            filter: blur(140px);
            opacity: 0.15;
            z-index: -1;
            animation: float 25s infinite ease-in-out alternate;
        }

        body::before {
            background: linear-gradient(135deg, #38bdf8, #818cf8);
            top: -200px;
            left: -200px;
            animation-delay: -5s;
        }

        body::after {
            background: linear-gradient(135deg, #818cf8, #c084fc);
            bottom: -200px;
            right: -200px;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 50px) scale(1.1); }
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 4rem;
            text-align: center;
            opacity: 0;
            animation: fadeInDown 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        }

        h1 {
            font-size: 3.25rem;
            font-weight: 800;
            margin-bottom: 1.25rem;
            letter-spacing: -0.03em;
            background: linear-gradient(135deg, #ffffff 0%, #cbd5e1 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }

        .subtitle {
            color: var(--accent-color);
            font-size: 1.05rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            font-weight: 500;
            background: var(--badge-bg);
            padding: 0.6rem 1.5rem;
            border-radius: 2rem;
            width: max-content;
            margin: 0 auto;
            border: 1px solid rgba(56, 189, 248, 0.2);
            box-shadow: 0 4px 12px rgba(56, 189, 248, 0.1);
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
            gap: 2rem;
        }

        .card {
            background: var(--card-bg);
            backdrop-filter: var(--glass-blur);
            -webkit-backdrop-filter: var(--glass-blur);
            border: 1px solid var(--border-color);
            border-radius: 1.5rem;
            padding: 2.25rem;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 100%);
            pointer-events: none;
        }

        .card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: rgba(56, 189, 248, 0.4);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 24px rgba(56, 189, 248, 0.15);
            background: rgba(30, 41, 59, 0.65);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            position: relative;
            z-index: 1;
        }

        .site-info {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .site-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, var(--accent-color), #818cf8);
            border-radius: 1.125rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            box-shadow: 0 8px 16px rgba(56, 189, 248, 0.3);
            flex-shrink: 0;
        }

        .site-name-link {
            text-decoration: none;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: color 0.2s ease;
        }

        .site-name-link:hover {
            color: var(--accent-color);
        }

        .site-name {
            font-size: 1.25rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        .site-id {
            font-size: 0.8rem;
            color: var(--text-secondary);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            margin-top: 0.35rem;
            opacity: 0.8;
            background: rgba(0,0,0,0.2);
            padding: 0.2rem 0.5rem;
            border-radius: 0.5rem;
            display: inline-block;
        }

        .card-body {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .description {
            font-size: 0.95rem;
            color: var(--text-secondary);
            line-height: 1.65;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .boards-section {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .boards-title {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-secondary);
            opacity: 0.8;
        }

        .boards-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .badge {
            background: var(--badge-bg);
            color: var(--badge-text);
            padding: 0.35rem 0.85rem;
            border-radius: 2rem;
            font-size: 0.8rem;
            font-weight: 600;
            border: 1px solid rgba(56, 189, 248, 0.15);
            transition: all 0.2s ease;
        }

        .card:hover .badge {
            background: rgba(56, 189, 248, 0.25);
            border-color: rgba(56, 189, 248, 0.35);
        }

        .meta-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            margin-top: auto;
        }

        .meta-item {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .meta-label {
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
        }

        .meta-value {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .meta-value i {
            color: var(--accent-color);
        }

        .rss-link {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            background: linear-gradient(to right, #38bdf8, #60a5fa);
            color: #fff;
            text-decoration: none;
            padding: 1rem;
            border-radius: 1.125rem;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            z-index: 1;
            box-shadow: 0 4px 12px rgba(56, 189, 248, 0.25);
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .rss-link::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
            transition: all 0.5s ease;
        }

        .rss-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(56, 189, 248, 0.45);
        }

        .rss-link:hover::after {
            left: 100%;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 768px) {
            body { padding: 2rem 1.25rem; }
            h1 { font-size: 2.25rem; }
            .grid { grid-template-columns: 1fr; }
            .card { padding: 1.75rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>RSS 피드 대시보드</h1>
            <div class="subtitle">
                <i data-lucide="info" size="18"></i>
                최대 수집 게시글 수: <strong>{{ .feedConfig.MaxItemCount }}</strong>개
            </div>
        </header>

        <main class="grid">
            {{ $baseURL := .baseURL }}
            {{ range .feedConfig.Providers }}
            <section class="card">
                <div class="card-header">
                    <div class="site-info">
                        <div class="site-icon">
                            <i data-lucide="rss" size="24"></i>
                        </div>
                        <div>
                            <a href="{{ .Config.URL }}" target="_blank" class="site-name-link">
                                <span class="site-name">{{ .Config.Name }}</span>
                                <i data-lucide="external-link" size="14" style="opacity: 0.6; color: var(--text-secondary);"></i>
                            </a>
                            <div class="site-id">{{ .ID }}</div>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <p class="description">{{ .Config.Description }}</p>
                    
                    <div class="boards-section">
                        <div class="boards-title">게시판 목록</div>
                        <div class="boards-list">
                            {{ range .Config.Boards }}
                            <span class="badge">{{ .Name }}</span>
                            {{ end }}
                        </div>
                    </div>

                    <div class="meta-info">
                        <div class="meta-item">
                            <div class="meta-label">수집 주기</div>
                            <div class="meta-value">
                                <i data-lucide="calendar-clock" size="16"></i>
                                {{ .Scheduler.TimeSpec }}
                            </div>
                        </div>
                        <div class="meta-item">
                            <div class="meta-label">보관 기간</div>
                            <div class="meta-value">
                                <i data-lucide="archive" size="16"></i>
                                {{ .Config.ArchiveDays }}일
                            </div>
                        </div>
                    </div>
                </div>

                <a href="{{ $baseURL }}/{{ .ID }}.xml" target="_blank" class="rss-link">
                    <i data-lucide="radio" size="18"></i>
                    RSS 피드 구독하기
                </a>
            </section>
            {{ end }}
        </main>
    </div>

    <script>
        // Lucide 아이콘 렌더링
        lucide.createIcons();
        
        // 카드에 순차적 렌더링 딜레이 추가 (애니메이션)
        document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll('.card').forEach((card, index) => {
                card.style.animationDelay = `${index * 0.15 + 0.2}s`;
            });
        });
    </script>
</body>
</html>
{{ end }}
